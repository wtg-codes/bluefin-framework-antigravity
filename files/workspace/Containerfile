FROM ghcr.io/ublue-os/ubuntu-toolbox:latest

# 1. Install system dependencies
RUN apt-get update && apt-get install -y \
    git \
    curl \
    wget \
    jq \
    gnupg \
    python3-pip \
    pipx \
    nodejs \
    npm \
    apt-transport-https \
    && rm -rf /var/lib/apt/lists/*

# 2. Install Google Chrome for agent-based browsing
RUN wget -q -O - https://dl-ssl.google.com/linux/linux_signing_key.pub | gpg --dearmor -o /usr/share/keyrings/googlechrome-linux-keyring.gpg \
    && echo 'deb [arch=amd64 signed-by=/usr/share/keyrings/googlechrome-linux-keyring.gpg] https://dl.google.com/linux/chrome/deb/ stable main' > /etc/apt/sources.list.d/google.list \
    && apt-get update && apt-get install -y google-chrome-stable && rm -rf /var/lib/apt/lists/*

# 3. Install Google Antigravity IDE and apply Sandbox Wrappers
RUN mkdir -p /etc/apt/keyrings \
    && curl -fsSL https://us-central1-apt.pkg.dev/doc/repo-signing-key.gpg | gpg --dearmor --yes -o /etc/apt/keyrings/antigravity-repo-key.gpg \
    && echo "deb [signed-by=/etc/apt/keyrings/antigravity-repo-key.gpg] https://us-central1-apt.pkg.dev/projects/antigravity-auto-updater-dev/ antigravity-debian main" > /etc/apt/sources.list.d/antigravity-ide.list \
    && apt-get update && apt-get install -y antigravity && rm -rf /var/lib/apt/lists/*

# Apply wrappers for Electron/Chrome stability in containers
RUN mv /usr/bin/google-chrome-stable /usr/bin/google-chrome-stable.orig \
    && printf '#!/bin/bash\nexec /usr/bin/google-chrome-stable.orig --disable-dev-shm-usage "$@"' > /usr/bin/google-chrome-stable \
    && chmod +x /usr/bin/google-chrome-stable \
    && if [ -f /usr/bin/antigravity ]; then \
       mv /usr/bin/antigravity /usr/bin/antigravity.orig; \
       printf '#!/bin/bash\nexec /usr/bin/antigravity.orig --disable-dev-shm-usage "$@"' > /usr/bin/antigravity; \
       chmod +x /usr/bin/antigravity; \
       fi


# 4. Install CNCF Tooling
# Install kubectl
RUN curl -LO "https://dl.k8s.io/release/v1.36.0/bin/linux/amd64/kubectl" \
    && echo "123d8c8844f46b1244c547fffb3c17180c0c26dac9890589fe7e67763298748e  kubectl" | sha256sum -c - \
    && install -o root -g root -m 0755 kubectl /usr/local/bin/kubectl \
    && rm kubectl

# Install k9s
RUN curl -sSLO "https://github.com/derailed/k9s/releases/download/v0.50.18/k9s_Linux_amd64.tar.gz" \
    && echo "0b697ed4aa80997f7de4deeed6f1fba73df191b28bf691b1f28d2f45fa2a9e9b  k9s_Linux_amd64.tar.gz" | sha256sum -c - \
    && tar -xzf k9s_Linux_amd64.tar.gz k9s \
    && install -o root -g root -m 0755 k9s /usr/local/bin/k9s \
    && rm k9s_Linux_amd64.tar.gz k9s

# Install helm
RUN curl -fsSL https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 -o get_helm.sh \
    && echo "38b65f882d9cae3891755bdb03becc6a01ae6f9cb24826c191f219ddfee70a5d  get_helm.sh" | sha256sum -c - \
    && chmod 700 get_helm.sh \
    && ./get_helm.sh \
    && rm get_helm.sh

# 5. Install AI Agent Dependencies
# Gemini CLI
RUN npm install -g @google/gemini-cli

# Google ADK (Agent Development Kit)
# Using --ignore-installed to resolve PyYAML conflict observed in CI
ENV PIPX_HOME=/opt/pipx PIPX_BIN_DIR=/usr/local/bin
RUN pipx install google-adk --pip-args="--retries 10"

LABEL org.opencontainers.image.description="Declarative Student Workspace for wtgOS Cloud-Native Laboratory"
